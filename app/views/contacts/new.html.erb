<% content_for(:title, "お問い合わせ") %>

<div class="static-page">
  <div class="static-page__container">
    <!-- タイトル -->
    <h1 class="contact-page__title">お問い合わせ</h1>
    <p class="contact-page__subtitle">ご質問・ご要望などお気軽にお問い合わせください</p>

    <!-- コンテンツカード -->
    <div class="static-page__content">
      <%= form_with model: @contact, url: contact_path, local: true, class: "contact-form" do |f| %>
        <% if @contact.errors.any? %>
          <div class="contact-form__errors">
            <ul>
              <% @contact.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="contact-form__field">
          <%= f.label :name, "お名前（必須）", class: "contact-form__label" %>
          <%= f.text_field :name, maxlength: 100, class: "contact-form__input", placeholder: "山田 太郎" %>
        </div>

        <div class="contact-form__field">
          <%= f.label :email, "メールアドレス（必須）", class: "contact-form__label" %>
          <%= f.email_field :email, required: true, class: "contact-form__input", placeholder: "example@email.com" %>
        </div>

        <div class="contact-form__field">
          <%= f.label :message, "お問い合わせ内容（必須）", class: "contact-form__label" %>
          <%= f.text_area :message, required: true, maxlength: 5000, rows: 8, class: "contact-form__input contact-form__textarea", placeholder: "お問い合わせ内容をご記入ください" %>
        </div>

        <%# HoneyPot %>
        <div class="contact-form__honeypot" aria-hidden="true">
          <%= hidden_field_tag :website, "", autocomplete: "off", tabindex: "-1" %>
        </div>

        <div class="contact-form__actions">
          <%= f.submit "送信する", class: "contact-form__submit", data: { loading_text: "送信中..." } %>
        </div>
      <% end %>
    </div>
  </div>
</div>
